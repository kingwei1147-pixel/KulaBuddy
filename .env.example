# Built-in GGUF runtime (default, no API key needed)
PLANNER_MODEL=builtin:default
EXECUTOR_MODEL=builtin:default
CRITIC_MODEL=builtin:default

# Optional: Cloud API (OpenAI-compatible)
# CLOUD_MODEL_ENDPOINT=https://api.openai.com/v1
# CLOUD_API_KEY=
# PLANNER_MODEL=cloud:gpt-4o-mini

# Optional: Local inference servers
# LOCAL_MODEL_ENDPOINT=http://127.0.0.1:11434
# LMSTUDIO_ENDPOINT=http://127.0.0.1:1234/v1
# VLLM_ENDPOINT=http://127.0.0.1:8000/v1
# LLAMA_CPP_ENDPOINT=http://127.0.0.1:8080/v1

# Media generation (optional)
COMFYUI_ENDPOINT=http://127.0.0.1:8188
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

AUTO_DETECT_MODELS=true
GRANTED_SCOPES=filesystem.read,filesystem.write,shell.exec,web.fetch,code.exec
ALLOW_HIGH_RISK_TOOLS=false
MAX_PLANNING_CYCLES=4
MAX_UPLOAD_BYTES=10485760
EXPERIENCE_STORE_PATH=./.agent/experiences.json
AUTOMATION_STORE_PATH=./.agent/automations.json
TASK_STORE_PATH=./.agent/tasks.json
MEDIA_JOB_STORE_PATH=./.agent/media-jobs.json
APPROVAL_STORE_PATH=./.agent/approvals.json
UPLOADS_DIR=./.agent/uploads
ARTIFACTS_DIR=./.agent/artifacts
GENERATED_MEDIA_DIR=./.agent/generated
AUTOMATION_POLL_MS=30000
MAX_CONCURRENT_TASKS=1
DISABLE_VERIFIER=false
MAX_TASK_RETRIES=1
FAILURE_REPLAY_LIMIT=3
REQUIRE_APPROVAL_FOR_HIGH_RISK=true
APPROVAL_POLICY_PRESET=balanced
APPROVAL_AUTO_ALLOW_COMMANDS=
READ_ROOTS=.
WRITE_ROOTS=.
SHELL_ALLOWLIST=node,npm,pnpm,git,python,pytest
WEB_ALLOWLIST=github.com,raw.githubusercontent.com

# ── Search ───────────────────────────────────────────────────────────
# Free: DaDa uses DDG + Bing HTML scraping (no config needed, but slower/less reliable)
# Brave Search API — 2000 free queries/month, no credit card required
# Sign up at https://brave.com/search/api/ → get API key → uncomment below
# BRAVE_SEARCH_API_KEY=
# Serper.dev Google Search API — 2500 free queries/month at https://serper.dev
# SERPER_API_KEY=
# Self-hosted: SearXNG meta-search engine (Docker: docker run -d -p 8888:8080 searxng/searxng)
# SEARXNG_ENDPOINT=http://192.168.1.100:8888

PORT=9877
